---
import BaseLayout from "../layouts/BaseLayout.astro";
import AchievementModal from "../components/interactive/AchievementModal";
import { storiesByLevel as allStories } from "../data/stories";

const levelMeta: Record<string, { label: string; color: string }> = {
  "a1": { label: "A1 \u2014 Beginner", color: "a1" },
  "a2": { label: "A2 \u2014 Elementary", color: "a2" },
  "b1": { label: "B1 \u2014 Intermediate", color: "b1" },
  "b1+": { label: "B1+ \u2014 Upper Intermediate", color: "b1p" },
  "b2": { label: "B2 \u2014 Advanced", color: "b2" },
  "b2+": { label: "B2+ \u2014 Pre-Advanced", color: "b2p" },
};

const levels = ["a1", "a2", "b1", "b1+", "b2", "b2+"];

function shortDesc(level: string, words: number, id: string): string {
  const descs: Record<string, string> = {
    "a1-my-family": "Introducing family members.",
    "a1-school": "A day at school.",
    "a1-food": "Favorite foods and meals.",
    "a2-shopping": "Choosing clothes at a store.",
    "a2-restaurant": "Trying a new place to eat.",
    "a2-weather": "Weather and seasons description.",
    "a2-hobbies": "Different hobbies and activities.",
    "a2-city": "City life compared to the countryside.",
    "b1-environment": "Environmental awareness.",
    "b1-job-interview": "Preparing for and doing a job interview.",
    "b1-health": "Health and fitness habits.",
    "b1-tech": "How technology affects daily life.",
    "b1-culture": "Different cultural celebrations.",
    "b1p-relationships": "Navigating modern relationships.",
    "b1p-city-life": "Life in a modern city.",
    "b1p-traditions": "Cultural traditions around the world.",
    "b1p-environment": "Facing environmental challenges.",
    "b1p-social-media": "The impact of social media.",
    "b1p-learning": "The journey of learning a language.",
    "b2-psychology": "Basic psychology concepts.",
    "b2-economics": "Economic systems explained.",
    "b2-science": "Important scientific findings.",
    "b2-art": "Art movements and their impact.",
    "b2-society": "Social changes in modern times.",
    "b2p-business": "Modern business strategies.",
    "b2p-politics": "Understanding political systems.",
    "b2p-philosophy": "Introducing philosophical ideas.",
    "b2p-literature": "The power of literature.",
    "b2p-persuasion": "The art of persuasion.",
    "b2p-leadership": "What makes a great leader?",
    "a1-my-day": "A simple story about daily routines.",
    "a1-toms-pet": "Tom has a friendly cat named Whiskers.",
    "a1-the-park": "Sarah and Ben play at the park.",
    "a2-weekend-trip": "Maria\u2019s weekend trip to the beach.",
    "b1-travel-story": "Alex\u2019s first trip abroad.",
    "b2-innovation": "Technological breakthroughs and society.",
  };
  return descs[id] || `A level ${level} story.`;
}
---

<BaseLayout title="Reading" description="Leveled reading comprehension stories with vocabulary support. Practice reading at your CEFR level.">
  <section class="mx-auto max-w-5xl px-4 sm:px-4 py-8 sm:py-12">
    <div class="mb-6 sm:mb-8 text-center">
      <span class="inline-block rounded-full bg-b1-bg px-4 py-1 text-sm font-semibold text-b1">Reading</span>
      <h1 class="mt-3 text-3xl sm:text-4xl font-bold font-display">Reading Library</h1>
      <p class="mx-auto mt-2 max-w-lg text-text-secondary">
        Leveled stories with comprehension questions. Tap highlighted words to see definitions and save them to your vocabulary.
      </p>
    </div>

    <div class="space-y-12">
      {levels.map((level) => {
        const stories = allStories[level] || [];
        const meta = levelMeta[level];
        const difficulty = level === "a1" || level === "a2" ? "Easy" : level === "b1" || level === "b1+" ? "Medium" : "Hard";
        return (
          <div key={level}>
            <h2 class="mb-4 text-2xl font-bold font-display" style={{ color: `var(--${meta.color})` }}>
              {meta.label}
            </h2>
            <div class="grid gap-4 md:grid-cols-2">
              {stories.map((s, i) => (
                <a
                  href={`/reading/${s.id}`}
                  class="group block rounded-xl shadow-border bg-surface p-5 transition-shadow transition-transform hover:shadow-border-hover hover:-translate-y-0.5 active-scale animate-fade-in-up"
                  style={`animation-delay: ${i * 80}ms`}
                >
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="font-semibold group-hover:text-text">{s.title}</h3>
                    <span class="shrink-0 rounded-full px-2 py-0.5 text-xs font-medium" style={{ background: `var(--${meta.color}-bg)`, color: `var(--${meta.color})` }}>
                      {s.level.toUpperCase()}
                    </span>
                  </div>
                  <p class="mt-1 text-sm text-text-secondary">{shortDesc(level, s.words, s.id)}</p>
                  <div class="mt-3 flex items-center gap-3 text-xs text-text-muted">
                    <span>{s.words} words</span>
                    <span>{difficulty}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>
  <AchievementModal client:load />
</BaseLayout>
