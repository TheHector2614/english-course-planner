---
import BaseLayout from "../layouts/BaseLayout.astro";
import AchievementModal from "../components/interactive/AchievementModal";

const resourceCategories = [
  {
    title: "YouTube Channels",
    icon: "video",
    color: "incorrect",
    resources: [
      { name: "BBC Learning English", url: "https://www.youtube.com/@bbclearningenglish", desc: "Official BBC channel with news-based lessons, pronunciation, grammar, and vocabulary for all levels.", level: "A1-B2" },
      { name: "English with Lucy", url: "https://www.youtube.com/@EnglishWithLucy", desc: "Clear, friendly British English lessons covering grammar, pronunciation, and vocabulary.", level: "A2-B2" },
      { name: "Rachel\u2019s English", url: "https://www.youtube.com/@rachelsenglish", desc: "In-depth American English pronunciation and accent training.", level: "B1-B2" },
      { name: "EngVid", url: "https://www.youtube.com/@engvidAdam", desc: "Short, focused lessons on grammar, vocabulary, and exam preparation.", level: "A1-B2" },
      { name: "TED-Ed", url: "https://www.youtube.com/@TEDEd", desc: "Animated educational videos with subtitles. Great for listening practice.", level: "B1-C1" },
      { name: "VOA Learning English", url: "https://www.youtube.com/@VOALearningEnglish", desc: "News stories read at a slower pace with vocabulary explanations.", level: "A2-B1" },
    ],
  },
  {
    title: "Podcasts",
    icon: "headphones",
    color: "a2",
    resources: [
      { name: "6 Minute English (BBC)", url: "https://www.bbc.co.uk/learningenglish/english/features/6-minute-english", desc: "Short 6-minute episodes on interesting topics with vocabulary focus.", level: "B1-B2" },
      { name: "The English We Speak", url: "https://www.bbc.co.uk/learningenglish/english/features/the-english-we-speak", desc: "2-3 minute episodes explaining modern English idioms and expressions.", level: "B1-B2" },
      { name: "ESL Pod", url: "https://www.eslpod.com", desc: "Slow, clear English with explanations. Good for intermediate learners.", level: "A2-B1" },
      { name: "Luke\u2019s English Podcast", url: "https://teacherluke.co.uk", desc: "Longer, natural conversations on many topics with humor.", level: "B1-C1" },
      { name: "Culips ESL Podcast", url: "https://esl.culips.com", desc: "Real English conversations with transcripts and vocabulary help.", level: "B1-C1" },
    ],
  },
  {
    title: "Interactive Tools",
    icon: "tool",
    color: "b1",
    resources: [
      { name: "Duolingo", url: "https://www.duolingo.com", desc: "Free gamified language learning app. Great for daily practice.", level: "A1-B1" },
      { name: "Quizlet", url: "https://quizlet.com", desc: "Create or use flashcard sets for vocabulary practice.", level: "A1-B2" },
      { name: "Anki", url: "https://apps.ankiweb.net", desc: "Advanced spaced-repetition flashcard system (desktop + mobile).", level: "A1-C2" },
      { name: "YouGlish", url: "https://youglish.com", desc: "Search words and hear them in real YouTube videos.", level: "A2-C2" },
      { name: "Grammarly", url: "https://www.grammarly.com", desc: "Writing assistant that checks grammar, style, and tone.", level: "B1-C2" },
    ],
  },
  {
    title: "Reading & News",
    icon: "book",
    color: "correct",
    resources: [
      { name: "News in Levels", url: "https://www.newsinlevels.com", desc: "Same news story written at 3 different difficulty levels.", level: "A2-B2" },
      { name: "Breaking News English", url: "https://breakingnewsenglish.com", desc: "News-based lessons with activities, graded by level.", level: "A2-B2" },
      { name: "Simple Wikipedia", url: "https://simple.wikipedia.org", desc: "Wikipedia articles written in simpler English.", level: "A2-B1" },
      { name: "ReadTheory", url: "https://readtheory.org", desc: "Free reading comprehension exercises that adapt to your level.", level: "A1-C1" },
    ],
  },
  {
    title: "Grammar References",
    icon: "reference",
    color: "b2",
    resources: [
      { name: "Perfect English Grammar", url: "https://www.perfect-english-grammar.com", desc: "Clear explanations and exercises for all grammar topics.", level: "A1-C1" },
      { name: "British Council Grammar", url: "https://learnenglish.britishcouncil.org/grammar", desc: "Official British Council grammar reference with exercises.", level: "A1-C1" },
      { name: "Cambridge Dictionary", url: "https://dictionary.cambridge.org", desc: "Learner\u2019s dictionary with grammar labels and examples.", level: "A1-C2" },
      { name: "Oxford Learner\u2019s Dictionaries", url: "https://www.oxfordlearnersdictionaries.com", desc: "Oxford dictionaries for English learners.", level: "A1-C2" },
    ],
  },
];

const colorMap: Record<string, string> = {
  video: "M8 5v14l11-7z",
  headphones: "M22 17a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9.5C2 5.36 5.36 2 9.5 2h5C18.64 2 22 5.36 22 9.5V17z M20 17v2a2 2 0 0 1-2 2h-3",
  tool: "M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z",
  book: "M4 19.5A2.5 2.5 0 0 1 6.5 17H20 M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z",
  reference: "M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z",
};
---

<BaseLayout title="Resources" description="Curated English learning resources: YouTube channels, podcasts, tools, reading materials, and grammar references.">
  <section class="mx-auto max-w-4xl px-4 py-12">
    <div class="mb-8 text-center">
      <span class="inline-block rounded-full bg-b1p-bg px-4 py-1 text-sm font-semibold text-b1p">Resources</span>
      <h1 class="mt-3 text-4xl font-bold font-display">Learning Resources</h1>
      <p class="mx-auto mt-2 max-w-lg text-text-secondary">
        Curated collection of the best free English learning resources \u2014 YouTube channels, podcasts, tools, and references.
      </p>
    </div>

    {resourceCategories.map((cat) => (
      <div class="mb-12">
        <div class="mb-4 flex items-center gap-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg" style={{ background: `var(--${cat.color}-bg)` }}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={`var(--${cat.color})`} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={colorMap[cat.icon] || colorMap.book} />
            </svg>
          </div>
          <h2 class="text-2xl font-bold font-display" style={{ color: `var(--${cat.color})` }}>{cat.title}</h2>
        </div>
        <div class="grid gap-3 md:grid-cols-2">
          {cat.resources.map((r) => (
            <a
              href={r.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group block rounded-xl shadow-border bg-surface p-4 no-underline transition-shadow transition-transform hover:shadow-border-hover hover:-translate-y-0.5"
            >
              <div class="flex items-start justify-between gap-2">
                <h3 class="font-semibold text-sm group-hover:text-text">{r.name}</h3>
                <span class="shrink-0 rounded-full px-2 py-0.5 text-xs font-medium" style={{ background: `var(--${cat.color}-bg)`, color: `var(--${cat.color})` }}>
                  {r.level}
                </span>
              </div>
              <p class="mt-1 text-xs text-text-secondary">{r.desc}</p>
              <div class="mt-2 flex items-center gap-1 text-xs text-text-muted">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Open
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
  <AchievementModal client:load />
</BaseLayout>
