        { incorrect: "I wish I was taller.", correct: "I wish I were taller.", explanation: "After 'wish', use 'were' for all subjects in formal English (subjunctive mood)." },
        { incorrect: "I'd rather you don't smoke in here.", correct: "I'd rather you didn't smoke in here.", explanation: "After 'would rather' + different subject, use past tense." },
        { incorrect: "It's high time we will leave.", correct: "It's high time we left.", explanation: "After 'it's high time', use past tense (subjunctive), not 'will'." },
      ],
      sentenceTransformation: [
        { prompt: "Because the company invested in new technology, it grew faster.", startWith: "Given", correct: ["Given that the company invested in new technology, it grew faster.", "Given the investment in new technology, the company grew faster."], hint: "Participle clause with 'given'", explanation: "'Because' → 'Given that' or 'Given + noun phrase' to sound more formal." },
        { prompt: "I regret not accepting the job offer.", startWith: "I wish", correct: ["I wish I had accepted the job offer."], hint: "Wish + past perfect for past regret", explanation: "'Regret not doing' → 'wish + had + past participle'." },
        { prompt: "She prefers that we don't smoke in the office.", startWith: "She'd rather", correct: ["She'd rather we didn't smoke in the office."], hint: "'Would rather' + subject + past", explanation: "'Prefer that + subject + don't' → 'would rather + subject + didn't'." },
        { prompt: "We should probably start the meeting now.", startWith: "It's high time", correct: ["It's high time we started the meeting.", "It's high time we began the meeting."], hint: "Fixed expression with past subjunctive", explanation: "It's high time + subject + past tense." },
      ],
    }},
  ];
}
---

<BaseLayout title={`Level ${level} — ${label}`}>
  <section class="mx-auto max-w-6xl px-4 py-8 sm:py-12">
    <!-- Level Header -->
    <div class="mb-8 sm:mb-12 relative">
      <div class="absolute -inset-10 rounded-full bg-radial-gradient from-focus-accent-light/10 to-transparent blur-3xl pointer-events-none -z-10"></div>
      <div class="flex items-center justify-between flex-wrap gap-4">
        <div class="flex items-center gap-4">
          <span class="text-4xl sm:text-5xl font-black font-display tracking-tight" style={`color: var(--${color});`}>
            {name}
          </span>
          <span class="rounded-full px-4 py-1 text-sm font-bold border" style={`background: var(--${color}-bg); color: var(--${color}); border-color: color-mix(in oklch, var(--${color}) 20%, transparent)`}>
            {label}
          </span>
        </div>
        <span id="level-mode-badge" class="rounded-full px-3.5 py-1.5 text-xs font-bold uppercase tracking-wider" style="background: var(--focus-accent-bg); color: var(--focus-accent); border: 1px solid color-mix(in oklch, var(--focus-accent) 20%, transparent)">General</span>
      </div>
      <p class="mt-4 text-base sm:text-lg text-text-secondary leading-relaxed font-medium">{units.length} units · ~{(units.length * 3)} hours of study</p>
    </div>

    <!-- Units Grid -->
    <div class="mb-12 grid gap-4 md:grid-cols-2">
      {units.map((u, i) => (
        <div 
          class="unit-card glass-card rounded-[var(--radius-lg)] p-5 animate-fade-in-up" 
          style={`animation-delay: ${i * 80}ms; --hover-color: var(--${color}); --hover-shadow: color-mix(in oklch, var(--${color}) 18%, transparent);`}
        >
          <h3 class="text-lg font-bold font-display text-text">{u.title}</h3>
          <p class="mt-1 text-sm text-text-secondary leading-relaxed">{u.desc}</p>
          <div class="mt-4 flex gap-2">
            {u.tags.map((t) => (
              <span class="rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider" style={`background: var(--${color}-bg); color: var(--${color}); border: 1px solid color-mix(in oklch, var(--${color}) 15%, transparent)`}>
                {t}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Tab Bar (client-side) -->
    <LevelTabBar client:load />

    <!-- Core Grammar Tab -->
    <div data-tab="core">
      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Quiz</h2>
        <Quiz level={level} questions={quiz.questions} client:load />
      </div>

      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Fill in the Blank</h2>
        <FillBlank questions={fillBlank} level={level} client:load />
      </div>
      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Matching</h2>
        <Matching pairs={matchPairs} level={level} client:load />
      </div>

      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Sentence Reorder</h2>
        <SentenceReorder questions={reorder} level={level} client:load />
      </div>

      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Vocabulary Flashcards</h2>
        <FlashcardDeck cards={flashcards} client:load />
      </div>
    </div>

    <!-- Business Skills Tab -->
    <div data-tab="business" class="hidden">
      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Business Quiz</h2>
        <Quiz level={level} questions={business.quiz.questions} client:load />
      </div>

      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Business Fill in the Blank</h2>
        <FillBlank questions={business.fillBlank} level={level} client:load />
      </div>

      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Business Vocabulary</h2>
        <Matching pairs={business.matchPairs} level={level} client:load />
      </div>

      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Business Sentence Reorder</h2>
        <SentenceReorder questions={business.reorder} level={level} client:load />
      </div>

      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Business Flashcards</h2>
        <FlashcardDeck cards={business.flashcards} client:load />
      </div>

      {business.speaking && business.speaking.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Business Speaking</h2>
          <SpeakingPractice items={business.speaking} level={level} client:load />
        </div>
      )}

      {business.dictation && business.dictation.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Business Dictation</h2>
          <Dictation items={business.dictation} level={level} client:load />
        </div>
      )}

      {business.listening && business.listening.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Business Listening</h2>
          <ListeningExercise questions={business.listening} level={level} client:load />
        </div>
      )}

      {business.errorCorrection && business.errorCorrection.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Business Error Correction</h2>
          <ErrorCorrection questions={business.errorCorrection} level={level} client:load />
        </div>
      )}

      {business.sentenceTransformation && business.sentenceTransformation.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Business Sentence Transformation</h2>
          <SentenceTransformation questions={business.sentenceTransformation} level={level} client:load />
        </div>
      )}

      {business.clozePassage && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Business Cloze Passage</h2>
          <ClozePassage title={`${name} Business`} text={business.clozePassage.text} blanks={business.clozePassage.blanks} level={level} client:load />
        </div>
      )}
    </div>

    <!-- Tech Terms Tab -->
    <div data-tab="tech" class="hidden">
      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Tech Quiz</h2>
        <Quiz level={level} questions={tech.quiz.questions} client:load />
      </div>

      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Tech Fill in the Blank</h2>
        <FillBlank questions={tech.fillBlank} level={level} client:load />
      </div>

      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Tech Vocabulary</h2>
        <Matching pairs={tech.matchPairs} level={level} client:load />
      </div>

      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Tech Sentence Reorder</h2>
        <SentenceReorder questions={tech.reorder} level={level} client:load />
      </div>

      <div class="mb-12">
        <h2 class="mb-4 text-2xl font-bold font-display">Tech Flashcards</h2>
        <FlashcardDeck cards={tech.flashcards} client:load />
      </div>

      {tech.speaking && tech.speaking.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Tech Speaking</h2>
          <SpeakingPractice items={tech.speaking} level={level} client:load />
        </div>
      )}

      {tech.dictation && tech.dictation.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Tech Dictation</h2>
          <Dictation items={tech.dictation} level={level} client:load />
        </div>
      )}

      {tech.listening && tech.listening.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Tech Listening</h2>
          <ListeningExercise questions={tech.listening} level={level} client:load />
        </div>
      )}

      {tech.errorCorrection && tech.errorCorrection.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Tech Error Correction</h2>
          <ErrorCorrection questions={tech.errorCorrection} level={level} client:load />
        </div>
      )}

      {tech.sentenceTransformation && tech.sentenceTransformation.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Tech Sentence Transformation</h2>
          <SentenceTransformation questions={tech.sentenceTransformation} level={level} client:load />
        </div>
      )}

      {tech.clozePassage && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Tech Cloze Passage</h2>
          <ClozePassage title={`${name} Tech`} text={tech.clozePassage.text} blanks={tech.clozePassage.blanks} level={level} client:load />
        </div>
      )}
    </div>

    <!-- Practice Tab -->
    <div data-tab="practice" class="hidden">
      {speaking && speaking.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Speaking Practice</h2>
          <SpeakingPractice items={speaking} level={level} client:load />
        </div>
      )}

      {dictation && dictation.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Dictation</h2>
          <Dictation items={dictation} level={level} client:load />
        </div>
      )}

      {listening && listening.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Listening Comprehension</h2>
          <ListeningExercise questions={listening} level={level} client:load />
        </div>
      )}

      {errorCorrection && errorCorrection.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Error Correction</h2>
          <ErrorCorrection questions={errorCorrection} level={level} client:load />
        </div>
      )}

      {sentenceTransformation && sentenceTransformation.length > 0 && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Sentence Transformation</h2>
          <SentenceTransformation questions={sentenceTransformation} level={level} client:load />
        </div>
      )}

      {clozePassage && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Cloze Passage</h2>
          <ClozePassage title={clozePassage.title} text={clozePassage.text} blanks={clozePassage.blanks} level={level} client:load />
        </div>
      )}

      {level === "b1" && (
        <div class="mb-12">
          <h2 class="mb-4 text-2xl font-bold font-display">Writing Exercise</h2>
          <WritingExercise prompt="Describe your last vacation. Include where you went, what you did, and how you felt." minWords={80} maxWords={120} level={level} client:load />
        </div>
      )}
    </div>

    <!-- Progress Tab -->
    <div data-tab="progress" class="hidden">
      <div class="glass-card rounded-[var(--radius-lg)] p-5">
        <h3 class="text-lg font-bold font-display mb-4">Level Progress</h3>
        <div class="space-y-4">
          <div>
            <div class="flex items-center justify-between text-sm mb-1.5">
              <span class="font-semibold text-text-secondary">Units Completed</span>
              <span class="text-text-muted font-bold tabular-nums">0 / {units.length}</span>
            </div>
            <div class="h-3 rounded-full bg-surface-alt overflow-hidden p-0.5 border border-border-light">
              <div class="h-full rounded-full bg-focus-accent transition-all duration-500 ease-out" style="width: 0%"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between text-sm mb-1.5">
              <span class="font-semibold text-text-secondary">Quiz Best Score</span>
              <span class="text-text-muted font-bold tabular-nums">—</span>
            </div>
            <div class="h-3 rounded-full bg-surface-alt overflow-hidden p-0.5 border border-border-light">
              <div class="h-full rounded-full bg-focus-accent transition-all duration-500 ease-out" style="width: 0%"></div>
            </div>
          </div>
          <p class="text-sm text-text-secondary">Complete exercises and quizzes to track your progress in this level.</p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .unit-card {
      transition: border-color 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out), transform 0.3s var(--ease-out);
    }
    .unit-card:hover {
      border-color: var(--hover-color);
      box-shadow: 0 12px 28px -4px var(--hover-shadow);
      transform: translateY(-2px);
    }
  </style>

  <script>
    import { focusMode, FOCUS_LABELS } from "../../stores/modes";

    focusMode.subscribe(() => {
      const badge = document.getElementById("level-mode-badge");
      if (badge) badge.textContent = FOCUS_LABELS[focusMode.get()].split(" ")[0];
    });
  </script>
</BaseLayout>
