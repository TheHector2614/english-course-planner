---
import BaseLayout from "../layouts/BaseLayout.astro";
import AchievementModal from "../components/interactive/AchievementModal";
import DailyChallenge from "../components/interactive/DailyChallenge";
import DailyPlan from "../components/interactive/DailyPlan";

const levelIds = ["a1", "a2", "b1", "b1+", "b2", "b2+"];
const levelColors: Record<string, string> = { a1: "a1", a2: "a2", b1: "b1", "b1+": "b1p", b2: "b2", "b2+": "b2p" };
---

<BaseLayout title="Dashboard" description="View your learning progress, XP, streak, vocabulary stats, and achievements.">
  <section class="mx-auto max-w-5xl px-4 sm:px-4 py-8 sm:py-12">
    <div class="mb-6 sm:mb-8">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="inline-block rounded-full bg-b2-bg px-4 py-1 text-sm font-semibold text-b2">Dashboard</span>
        <span id="dash-mode-badge" class="rounded-full px-3 py-1 text-xs font-semibold" style="background: var(--focus-accent-bg); color: var(--focus-accent);">B1 · General</span>
      </div>
      <h1 class="mt-3 text-3xl sm:text-4xl font-bold font-display">Your Progress</h1>
      <p class="mt-2 text-text-secondary">Track your learning journey across all activities.</p>
    </div>

    <div class="space-y-6" id="dashboard-root">
      <!-- Stats Grid: populated by client JS -->
      <div class="grid gap-3 sm:gap-4 grid-cols-2 sm:grid-cols-2 md:grid-cols-4">
        <div class="glass-card glass-card-hover rounded-[var(--radius-lg)] p-5 transition-all duration-300 flex flex-col justify-between">
          <div class="flex items-center gap-2 text-sm text-text-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="color: var(--focus-accent)"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Study Streak
          </div>
          <p class="mt-2 text-2xl sm:text-3xl font-black font-display tracking-tight tabular-nums" id="streak-value">0 days</p>
        </div>
        <div class="glass-card glass-card-hover rounded-[var(--radius-lg)] p-5 transition-all duration-300 flex flex-col justify-between">
          <div class="flex items-center gap-2 text-sm text-text-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="color: var(--focus-accent)"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            Total XP
          </div>
          <p class="mt-2 text-2xl sm:text-3xl font-black font-display tracking-tight tabular-nums" id="xp-value">0</p>
        </div>
        <div class="glass-card glass-card-hover rounded-[var(--radius-lg)] p-5 transition-all duration-300 flex flex-col justify-between">
          <div class="flex items-center gap-2 text-sm text-text-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="color: var(--focus-accent)"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            Vocabulary
          </div>
          <p class="mt-2 text-2xl sm:text-3xl font-black font-display tracking-tight tabular-nums" id="vocab-value">0 words</p>
        </div>
        <div class="glass-card glass-card-hover rounded-[var(--radius-lg)] p-5 transition-all duration-300 flex flex-col justify-between">
          <div class="flex items-center gap-2 text-sm text-text-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="color: var(--focus-accent)"><line x1="22" y1="12" x2="2" y2="12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
            Levels Progress
          </div>
          <p class="mt-2 text-2xl sm:text-3xl font-black font-display tracking-tight tabular-nums" id="levels-value">0/6</p>
        </div>
      </div>

      <!-- XP Bar -->
      <div class="glass-card rounded-[var(--radius-lg)] p-5">
        <div class="flex items-center justify-between text-sm">
          <span class="font-semibold">Experience Level <span id="user-level" class="font-display font-black text-focus-accent">1</span></span>
          <span class="text-text-muted font-bold tabular-nums" id="xp-progress-text">0 / 500 XP</span>
        </div>
        <div class="mt-3.5 h-3 overflow-hidden rounded-full bg-surface-alt p-0.5 border border-border-light">
          <div id="xp-bar" class="h-full rounded-full transition-all duration-500 ease-out" style="width: 0%; background: linear-gradient(90deg, var(--a1), var(--a2), var(--b1))"></div>
        </div>
      </div>

      <!-- Level Completion -->
      <div class="glass-card rounded-[var(--radius-lg)] p-5">
        <h3 class="mb-4 text-sm font-bold uppercase tracking-wider text-text-muted">Level Completion</h3>
        <div class="space-y-3.5">
          {levelIds.map((l) => {
            const c = levelColors[l];
            return (
              <div class="flex items-center gap-4" key={l}>
                <span class="w-10 text-xs font-black font-display tracking-wider" style={{ color: `var(--${c})` }}>{l.toUpperCase()}</span>
                <div class="flex-1 h-3 rounded-full bg-surface-alt overflow-hidden p-0.5 border border-border-light">
                  <div class="h-full rounded-full transition-all duration-500" id={`bar-${l}`} style={{ width: "0%", background: `var(--${c})` }} />
                </div>
                <span class="w-8 text-right text-xs font-bold text-text-secondary tabular-nums" id={`pct-${l}`}>0%</span>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Challenges -->
      <DailyChallenge client:load />

      <!-- Daily Plan -->
      <DailyPlan client:load />

      <!-- Recent Activity -->
      <div class="glass-card rounded-[var(--radius-lg)] p-5">
        <h3 class="mb-4 text-sm font-bold uppercase tracking-wider text-text-muted">Recent Activity</h3>
        <div id="recent-activity" class="space-y-2.5">
          <p class="text-sm text-text-muted">No activity yet. Complete a quiz or read a story to get started!</p>
        </div>
      </div>

      <!-- Achievements -->
      <div class="glass-card rounded-[var(--radius-lg)] p-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-bold uppercase tracking-wider text-text-muted">Achievements</h3>
          <span class="text-xs font-bold text-text-secondary tabular-nums" id="achv-count">0 / 0</span>
        </div>
        <div id="achievement-grid" class="grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-6" />
      </div>
    </div>

    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a href="/dictionary" class="min-h-11 rounded-full px-6 py-2.5 text-sm font-semibold transition-all hover:shadow-md active-scale flex items-center justify-center gap-1.5" style="background: var(--a2-bg); color: var(--a2); border: 1px solid color-mix(in oklch, var(--a2) 20%, transparent);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
        Dictionary
      </a>
      <a href="/vocabulary" class="min-h-11 rounded-full px-6 py-2.5 text-sm font-semibold transition-all hover:shadow-md active-scale flex items-center justify-center gap-1.5" style="background: var(--a1-bg); color: var(--a1); border: 1px solid color-mix(in oklch, var(--a1) 20%, transparent);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>
        Vocabulary
      </a>
      <a href="/reading" class="min-h-11 rounded-full px-6 py-2.5 text-sm font-semibold transition-all hover:shadow-md active-scale flex items-center justify-center gap-1.5" style="background: var(--b1-bg); color: var(--b1); border: 1px solid color-mix(in oklch, var(--b1) 20%, transparent);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
        Reading
      </a>
      <a href="/resources" class="min-h-11 rounded-full px-6 py-2.5 text-sm font-semibold transition-all hover:shadow-md active-scale flex items-center justify-center gap-1.5" style="background: var(--b1p-bg); color: var(--b1p); border: 1px solid color-mix(in oklch, var(--b1p) 20%, transparent);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" /></svg>
        Resources
      </a>
    </div>
  </section>

  <script src="../scripts/dashboard.ts"></script>
  <AchievementModal client:load />
</BaseLayout>
