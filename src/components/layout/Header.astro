---
import ThemeToggle from "./ThemeToggle";
import LanguageToggle from "./LanguageToggle";
import ModeCarousel from "../interactive/ModeCarousel";
import LevelSelector from "./LevelSelector";

import { LEVELS } from "../../data/levels";

const features = [
  { href: "/dictionary", label: "Dictionary" },
  { href: "/vocabulary", label: "Vocabulary" },
  { href: "/reading", label: "Reading" },
  { href: "/crossword", label: "Crossword" },
  { href: "/resources", label: "Resources" },
];
---

<header class="sticky top-0 z-30 border-b border-border-light bg-surface/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <a href="/" class="flex items-center gap-2 text-lg font-bold font-display no-underline shrink-0">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
        <path d="M8 7h8" /><path d="M8 11h6" /><path d="M8 15h4" />
      </svg>
      <span>English Course</span>
    </a>
    <nav class="flex items-center gap-1 lg:gap-2" id="main-nav">
      <div class="flex items-center gap-1 lg:hidden">
        <button id="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-drawer" class="rounded-lg p-2.5 text-text-secondary hover:bg-surface-alt transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>

      <div class="hidden lg:flex items-center gap-1.5">
        {features.map((f) => (
          <a href={f.href} class="whitespace-nowrap rounded-full px-3 py-1.5 text-sm font-medium text-text-secondary transition-colors hover:bg-surface-alt">
            {f.label}
          </a>
        ))}
        <span class="mx-1 h-5 w-px bg-border" role="separator"></span>
        <LevelSelector client:only="react" />
      </div>

      <button id="header-mode-badge" type="button" class="hidden lg:flex items-center gap-1 rounded-full px-3 py-1.5 text-xs font-semibold transition-colors cursor-pointer" style="background: var(--focus-accent-bg); color: var(--focus-accent);" title="Click to cycle focus mode · Shift+click to cycle level" aria-label="Current mode">
        <span id="header-level-display" data-static="A1">A1</span>
        <span class="opacity-60">·</span>
        <span id="header-focus-display" data-static="General">General</span>
      </button>

      <a href="/dashboard" class="hidden lg:flex rounded-full bg-surface-alt px-3 py-1.5 text-sm text-text-secondary transition-colors hover:bg-border">
        Dashboard
      </a>
      <a href="/settings" class="hidden lg:flex rounded-full bg-surface-alt px-2 py-1.5 text-xs text-text-secondary transition-colors hover:bg-border" aria-label="Settings">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </a>
      <LanguageToggle client:only="react" />
      <ThemeToggle client:only="react" />
    </nav>
  </div>

  <div id="mobile-drawer" class="lg:hidden border-t border-border bg-surface animate-slide-down overflow-y-auto max-h-[calc(100vh-4rem)]" hidden>
    <div class="mx-auto max-w-6xl px-4 py-4 space-y-3">
      <div class="flex flex-wrap gap-2">
        {features.map((f) => (
          <a href={f.href} class="rounded-full min-h-11 px-4 py-2.5 text-sm font-medium text-text-secondary transition-colors hover:bg-surface-alt">
            {f.label}
          </a>
        ))}
      </div>
      <div class="pt-2 border-t border-border">
        <p class="mb-2 text-xs font-medium text-text-muted uppercase tracking-wider">Your Mode</p>
        <ModeCarousel compact client:only="react" />
      </div>
      <div class="pt-2 border-t border-border flex items-center gap-2">
        <a href="/dashboard" class="inline-flex min-h-11 rounded-full bg-surface-alt px-4 py-2.5 text-sm text-text-secondary transition-colors hover:bg-border">
          Dashboard
        </a>
        <a href="/settings" class="inline-flex min-h-11 rounded-full bg-surface-alt px-4 py-2.5 text-sm text-text-secondary transition-colors hover:bg-border">
          Settings
        </a>
      </div>
    </div>
  </div>

  <script src="../../scripts/header-mobile.ts"></script>
  <script src="../../scripts/header-mode.ts"></script>
</header>
