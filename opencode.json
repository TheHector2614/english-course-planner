{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "english-teacher",
  "agent": {
    "english-teacher-designer": {
      "description": "Profesor de inglés que diseña materiales didácticos HTML con diseño UI profesional.",
      "mode": "subagent",
      "temperature": 0.7,
      "permission": {
        "edit": "allow",
        "skill": { "*": "allow" },
        "glob": "allow",
        "grep": "allow",
        "read": "allow",
        "webfetch": "allow",
        "bash": "deny"
      }
    }
  }
}
